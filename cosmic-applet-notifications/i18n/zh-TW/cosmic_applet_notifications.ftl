hours-ago =
    { $duration ->
        [0] 剛剛
        [one] 1 小時前
       *[other] { $duration } 小時前
    }
minutes-ago =
    { $duration ->
        [0] 剛剛
        [one] 1 分鐘前
       *[other] { $duration } 分鐘前
    }
show-less = 顯示較少
show-more = 顯示其餘 { $more } 項
clear-group = 清除群組
clear-all = 清除所有通知
do-not-disturb = 勿擾模式
notification-settings = 通知設定…
no-notifications = 無通知
