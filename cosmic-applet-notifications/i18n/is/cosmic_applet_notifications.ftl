hours-ago =
    fyrir { $duration } { $duration ->
        [one] klst.
       *[other] klst.
    } síðan
minutes-ago =
    fyrir { $duration } { $duration ->
        [one] mínútu
       *[other] mínútum
    } síðan
show-less = Sýna minna
show-more = Sýna { $more } meira
clear-group = Hreinsa hóp
clear-all = Hreinsa allar tilkynningar
do-not-disturb = Ekki ónáða
notification-settings = Tilkynningastillingar...
no-notifications = Engar tilkynningar
