hours-ago =
    { $duration ->
        [0] ਹੁਣੇ ਹੀ
        [one] 1 ਘੰਟਾ ਪਹਿਲਾਂ
       *[other] { $duration } ਘੰਟੇ ਪਹਿਲਾਂ
    }
minutes-ago =
    { $duration ->
        [0] ਹੁਣੇ ਹੀ
        [one] 1 ਮਿੰਟ ਪਹਿਲਾਂ
       *[other] { $duration } ਮਿੰਟ ਪਹਿਲਾਂ
    }
show-less = ਘੱਟ ਵੇਖਾਓ
show-more = { $more } ਹੋਰ ਵੇਖਾਓ
clear-group = ਗਰੁੱਪ ਨੂੰ ਮਿਟਾਓ
clear-all = ਸਾਰੀਆਂ ਸੂਚਨਾਵਾਂ ਨੂੰ ਮਿਟਾਓ
do-not-disturb = ਤੰਗ ਨਾ ਕਰੋ
notification-settings = ਨੋਟੀਫਿਕੇਸ਼ਨ ਸੈਟਿੰਗਾਂ...
no-notifications = ਕੋਈ ਨੋਟੀਫਿਕੇਸ਼ਨ ਨਹੀਂ
